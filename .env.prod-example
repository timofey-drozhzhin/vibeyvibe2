# ======================
# vibeyvibe Environment (Production)
# ======================

# App
NODE_ENV=production

# Database (libSQL remote)
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=your-auth-token

# Auth
BETTER_AUTH_SECRET=your-secret-at-least-32-characters-long
BETTER_AUTH_URL=https://api.yourdomain.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Storage (Bunny CDN)
STORAGE_PROVIDER=bunny
STORAGE_LOCAL_PATH=
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_PASSWORD=your-storage-password
BUNNY_STORAGE_REGION=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=your-cdn-hostname.b-cdn.net
BUNNY_CDN_SECURITY_KEY=your-cdn-security-key

# No auth bypass in production
DEV_AUTH_BYPASS=

# Frontend
FRONTEND_URL=https://yourdomain.com

# AI
OPENROUTER_API_KEY=your-openrouter-api-key
SUNO_PROMPT_MODEL=
PROFILE_GENERATION_MODELS=
OPENROUTER_MODELS=

# CLI Queue Worker (optional, enables CLI-based AI processing)
CLI_MODELS=
CLI_API_BASE=https://api.yourdomain.com/api
CLAUDE_CLI=claude
GEMINI_CLI=gemini

# Spotify Web API (optional, enables official API — falls back to scraping if not set)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
