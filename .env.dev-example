# ======================
# vibeyvibe Environment (Development)
# ======================

# App
NODE_ENV=development

# Database (SQLite file, relative to apps/api/)
DATABASE_URL=file:../../tmp/local.db
DATABASE_AUTH_TOKEN=

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=../../tmp/storage
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_REGION=
BUNNY_CDN_HOSTNAME=
BUNNY_CDN_SECURITY_KEY=

# Dev Auth Bypass (only works when NODE_ENV !== "production")
DEV_AUTH_BYPASS=true

# Frontend
FRONTEND_URL=http://localhost:5173

# AI (optional, enables AI generation)
OPENROUTER_API_KEY=
SUNO_PROMPT_MODEL=
PROFILE_GENERATION_MODELS=
OPENROUTER_MODELS=

# CLI Queue Worker (optional, enables CLI-based AI processing)
CLI_MODELS=
CLI_API_BASE=http://localhost:3001/api
CLAUDE_CLI=claude
GEMINI_CLI=gemini

# Spotify Web API (optional, enables official API — falls back to scraping if not set)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
